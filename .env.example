# Earth911 / RecycleNation API key (server-only). Optional, without it /api/dropoffs returns curated stub data.
EARTH911_API_KEY=

# Google Gemini API key for the Sprout chat assistant. Free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional override for tile server attribution
NEXT_PUBLIC_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
